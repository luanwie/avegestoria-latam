generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url is configured in prisma.config.ts
}

// ── Auth.js Models (NextAuth v5 + @auth/prisma-adapter) ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("user") // user | admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  alerts   Alerta[]

  // Domain relations
  galpones       Galpon[]
  razas          Raza[]
  lotes          Lote[]
  clientes       Cliente[]
  ventas         Venta[]
  gastos         Gasto[]
  predicciones   Prediccion[]
  producciones   ProduccionDiaria[]
  chatLogs       ChatLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Domain Models (AveGestoria) ──

model Galpon {
  id              String   @id @default(cuid())
  userId          String
  nombre          String
  descripcion     String?
  capacidadMaxima Int?
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lotes Lote[]

  @@map("galpones")
}

model Raza {
  id                   String   @id @default(cuid())
  userId               String
  nombre               String
  productividadEsperada Decimal? @map("productividad_esperada") // % postura esperado
  pesoPromedio         Decimal? @map("peso_promedio") // gramos
  createdAt            DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lotes Lote[]

  @@map("razas")
}

model Lote {
  id             String    @id @default(cuid())
  userId         String
  galponId       String?   @map("galpon_id")
  razaId         String?   @map("raza_id")
  nombre         String
  cantidadAves   Int       @map("cantidad_aves")
  fechaIngreso   DateTime  @map("fecha_ingreso")
  fechaFinalizado DateTime? @map("fecha_finalizado")
  estado         String    @default("activo") // activo | finalizado | vendido
  costoAve       Decimal?  @map("costo_ave")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  galpon    Galpon? @relation(fields: [galponId], references: [id], onDelete: SetNull)
  raza      Raza?   @relation(fields: [razaId], references: [id], onDelete: SetNull)

  producciones    ProduccionDiaria[]
  gastos          Gasto[]
  predicciones    Prediccion[]

  @@map("lotes")
}

model ProduccionDiaria {
  id                String   @id @default(cuid())
  userId            String
  loteId            String   @map("lote_id")
  fecha             DateTime
  huevosColectados  Int      @map("huevos_colectados")
  huevosRotos       Int      @default(0) @map("huevos_rotos")
  huevosSucios      Int      @default(0) @map("huevos_sucios")
  huevosPartidos    Int      @default(0) @map("huevos_partidos")
  mortalidad        Int      @default(0)
  observaciones     String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lote Lote @relation(fields: [loteId], references: [id], onDelete: Cascade)

  @@unique([loteId, fecha])
  @@map("produccion_diaria")
}

model Cliente {
  id        String   @id @default(cuid())
  userId    String
  nombre    String
  telefono  String?
  direccion String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ventas Venta[]

  @@map("clientes")
}

model Venta {
  id              String   @id @default(cuid())
  userId          String
  clienteId       String?  @map("cliente_id")
  fecha           DateTime
  docenas         Int
  precioPorDocena Decimal  @map("precio_por_docena")
  metodoPago      String   @default("efectivo") @map("metodo_pago") // efectivo | transferencia | tarjeta | otro
  descripcion     String?
  createdAt       DateTime @default(now())

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@map("ventas")
}

model Gasto {
  id          String   @id @default(cuid())
  userId      String
  loteId      String?  @map("lote_id")
  categoria   String   // racion | medicinas | vacunas | electricidad | agua | mantenimiento | transporte | mano_obra | otro
  fecha       DateTime
  monto       Decimal
  descripcion String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lote Lote? @relation(fields: [loteId], references: [id], onDelete: SetNull)

  @@map("gastos")
}

model Prediccion {
  id        String   @id @default(cuid())
  userId    String
  loteId    String?  @map("lote_id")
  tipo      String   // produccion | mortalidad | costos
  dias      Int      // 30, 60, or 90
  resultado Json     @db.JsonB
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  lote Lote? @relation(fields: [loteId], references: [id], onDelete: SetNull)

  @@map("predicciones")
}

model Alerta {
  id        String   @id @default(cuid())
  userId    String
  tipo      String   // mortalidad_alta | produccion_baja | vacuna | economico
  mensaje   String
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alertas")
}

model ChatLog {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_logs")
}
